{
  "name": "WasslChat - Abandoned Cart Reminder (24h)",
  "nodes": [
    { "name": "Schedule", "type": "n8n-nodes-base.scheduleTrigger", "position": [250, 300], "parameters": { "rule": { "interval": [{ "field": "hours", "hoursInterval": 1 }] } } },
    { "name": "Get Pending Orders", "type": "n8n-nodes-base.httpRequest", "position": [450, 300], "parameters": {
      "url": "={{ $env.WASSLCHAT_API_URL }}/api/v1/orders?status=DRAFT&olderThan=24h", "method": "GET"
    } },
    { "name": "Loop Items", "type": "n8n-nodes-base.splitInBatches", "position": [650, 300], "parameters": { "batchSize": 1 } },
    { "name": "Send Reminder", "type": "n8n-nodes-base.httpRequest", "position": [850, 300], "parameters": {
      "url": "={{ $env.WASSLCHAT_API_URL }}/api/v1/whatsapp/send/text", "method": "POST",
      "body": { "phone": "={{ $json.contact.phone }}", "text": "مرحبا {{ $json.contact.name }} 👋\n\nلاحظنا إنك عندك طلب لسه ما تمّش ✨\n\n🛒 طلبك بقيمة {{ $json.total }} ج.م في انتظارك\n\nعايز تكمل الطلب؟ أرسل \"نعم\" 🙌" }
    } }
  ],
  "connections": { "Schedule": { "main": [[{ "node": "Get Pending Orders" }]] }, "Get Pending Orders": { "main": [[{ "node": "Loop Items" }]] }, "Loop Items": { "main": [[{ "node": "Send Reminder" }]] } }
}
